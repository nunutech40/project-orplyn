# Deployment identity. Keep the project name stable on a given host.
COMPOSE_PROJECT_NAME=orplyn-production
ORPLYN_RELEASE=replace-with-release-id
ORPLYN_IMAGE=orplyn-web:replace-with-release-id
ORPLYN_IMAGE_REPOSITORY=orplyn-web

# Existing reverse-proxy network on the current shared VPS.
# A future dedicated VPS can use a neutral network such as public-edge.
ORPLYN_EDGE_NETWORK=kohnu-production_edge

# Conservative limits for the current 2 vCPU / 2 GiB shared VPS.
ORPLYN_MEMORY_LIMIT=256m
ORPLYN_CPU_LIMIT=0.50

# These values are embedded into the image during build.
# Use the temporary hostname with indexing disabled until the final domain is ready.
NEXT_PUBLIC_SITE_URL=https://orplyn.103-59-94-121.nip.io
NEXT_PUBLIC_ALLOW_INDEXING=false
NEXT_PUBLIC_WHATSAPP_NUMBER=6282317579311
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_STARTED_LABEL=
GOOGLE_SITE_VERIFICATION=
