# Public URL used for canonical links, sitemap, robots, and social previews.
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Keep false on localhost/staging. Change to true only after the final domain,
# HTTPS, NAP, tracking, and launch QA are complete.
NEXT_PUBLIC_ALLOW_INDEXING=false

# Required before the site is used for real leads. Digits only, including country code.
# Confirmed by owner/admin form on 2026-07-17. Rebuild after changing this value.
NEXT_PUBLIC_WHATSAPP_NUMBER=6282317579311

# Optional Google tag and Google Ads lead-conversion configuration.
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Secondary conversion only: a valid brief opened WhatsApp.
NEXT_PUBLIC_GOOGLE_ADS_LEAD_STARTED_LABEL=

# Optional Google Search Console verification token.
GOOGLE_SITE_VERIFICATION=
